**/node_modules
**/.next
**/.turbo
**/dist
**/*.log
**/*.log.*
# TypeScript incremental cache — if copied stale, tsc skips emit thinking
# everything is up-to-date, leaving dist/ empty (silent build break).
**/*.tsbuildinfo
.git
.gitignore

# Local env files (injected via docker-compose environment)
.env
apps/**/.env
packages/**/.env

# Dev/test artifacts
**/__tests__
**/*.test.ts
**/*.spec.ts
**/coverage

# Uploads (mounted as volume)
apps/ocr-service/uploads
