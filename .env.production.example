# ============================================================
# FOXAI NATIVE – Production Environment Template
# Sao chép thành .env và điền giá trị thực tế trên server
# KHÔNG commit file .env vào git
# ============================================================

# ─── System DB ──────────────────────────────────────────────
SYSTEM_DB_USER=foxai_system
SYSTEM_DB_PASSWORD=CHANGE_ME_strong_password_1
SYSTEM_DB_NAME=system_db

# ─── OCR DB ─────────────────────────────────────────────────
OCR_DB_USER=foxai_ocr
OCR_DB_PASSWORD=CHANGE_ME_strong_password_2
OCR_DB_NAME=ocr_db

# ─── Chatbot DB ─────────────────────────────────────────────
CHATBOT_DB_USER=foxai_chatbot
CHATBOT_DB_PASSWORD=CHANGE_ME_strong_password_3
CHATBOT_DB_NAME=chatbot_db

# ─── Knowledge DB ───────────────────────────────────────────
KNOWLEDGE_DB_USER=foxai_kb
KNOWLEDGE_DB_PASSWORD=CHANGE_ME_strong_password_4
KNOWLEDGE_DB_NAME=knowledge_db

# ─── Redis (dùng Redis có sẵn trên host, không chạy trong Docker) ───────────
# host.docker.internal tự động trỏ đến host machine từ trong container (Linux Docker 20.10+)
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ────────────────────────────────────────────────────
# Tạo bằng: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_EXPIRES_IN=7d

# ─── OCR Provider ───────────────────────────────────────────
# Giá trị: mock | gemini | google-document-ai | aws-textract
OCR_PROVIDER=gemini
GEMINI_API_KEY=CHANGE_ME_your_gemini_api_key

# ─── LLM / Embedding ────────────────────────────────────────
OPENAI_API_KEY=CHANGE_ME_your_openai_api_key
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ─── BullMQ ─────────────────────────────────────────────────
BULLMQ_PREFIX=foxai
WORKER_CONCURRENCY=30

# ─── Frontend ───────────────────────────────────────────────
# URL công khai của API Gateway (từ góc nhìn browser)
# Ví dụ: https://your-domain.com/api
NEXT_PUBLIC_API_URL=http://your-server-ip/api

# ─── Misc ───────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
