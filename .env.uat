# ============================================================
# FOXAI NATIVE – UAT Environment
# Domain  : uatnative.foxai.com.vn
# KHÔNG commit file này vào git  (.gitignore phải có .env.uat)
# Khởi động: docker compose -f docker-compose.uat.yml --env-file .env.uat up -d --build
# ============================================================

# ─── System DB ──────────────────────────────────────────────
SYSTEM_DB_USER=uat_system
SYSTEM_DB_PASSWORD=CHANGE_ME_uat_strong_password_1
SYSTEM_DB_NAME=uat_system_db

# ─── OCR DB ─────────────────────────────────────────────────
OCR_DB_USER=uat_ocr
OCR_DB_PASSWORD=CHANGE_ME_uat_strong_password_2
OCR_DB_NAME=uat_ocr_db

# ─── Chatbot DB ─────────────────────────────────────────────
CHATBOT_DB_USER=uat_chatbot
CHATBOT_DB_PASSWORD=CHANGE_ME_uat_strong_password_3
CHATBOT_DB_NAME=uat_chatbot_db

# ─── Knowledge DB ───────────────────────────────────────────
KNOWLEDGE_DB_USER=uat_kb
KNOWLEDGE_DB_PASSWORD=CHANGE_ME_uat_strong_password_4
KNOWLEDGE_DB_NAME=uat_knowledge_db

# ─── Index DB ───────────────────────────────────────────────
INDEX_DB_USER=postgres
INDEX_DB_PASSWORD=CHANGE_ME_uat_strong_password_5
INDEX_DB_NAME=uat_index_py_db

# ─── Redis (host Redis dùng chung — cách ly bằng BULLMQ_PREFIX) ─
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ─────────────────────────────────────────────────────
# Tạo secret riêng cho UAT (khác với prod):
#   openssl rand -hex 32
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32_for_uat
JWT_EXPIRES_IN=7d

# ─── OCR Provider ────────────────────────────────────────────
OCR_PROVIDER=gemini
GEMINI_API_KEY=CHANGE_ME_your_gemini_api_key

# ─── LLM / Embedding ─────────────────────────────────────────
OPENAI_API_KEY=CHANGE_ME_your_openai_api_key
CLAUDE_API_KEY=

# ─── FoxAI LLM (index-service & chatbot-service) ─────────────
FOXAILLM_API_KEY=CHANGE_ME_foxaillm_api_key
FOXAILLM_BASE_URL=CHANGE_ME_foxaillm_base_url

# ─── BullMQ ──────────────────────────────────────────────────
# Prefix khác prod → hàng đợi UAT không xung đột với prod trên cùng Redis
BULLMQ_PREFIX=uat
WORKER_CONCURRENCY=3

# ─── MinIO UAT (port 9100:9000 / console 9101:9001) ──────────
MINIO_ROOT_USER=minio_uat
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_uat_password
# URL mà browser / client dùng để tải file từ MinIO UAT
# Nếu expose thẳng: http://<server-ip>:9100
# Nếu proxy qua nginx: https://uatnative.foxai.com.vn/minio
MINIO_PUBLIC_URL_BASE=http://CHANGE_ME_server_ip:9100

# ─── Qdrant ──────────────────────────────────────────────────
# Qdrant chạy trong stack UAT riêng → host = service name nội bộ
QDRANT_HOST=http://qdrant:6333
QDRANT_COLLECTION_NAME=foxai_uat
QDRANT_API_KEY=

# ─── Inter-service URLs (nội bộ docker-compose UAT) ──────────
# Các service gọi nhau qua service name trong network foxai-uat-internal
AUTH_SERVICE_URL=http://system-service:3002
INDEX_SERVICE_URL=http://index-service:8000
QUERY_SERVICE_URL=http://chatbot-service:8000

# ─── Public URL & Frontend ────────────────────────────────────
# NEXT_PUBLIC_API_URL được BAKE VÀO lúc build Next.js → phải đúng domain UAT
# Không đặt port ở đây — nginx đã reverse proxy chuẩn hóa về 443
NEXT_PUBLIC_API_URL=https://uatnative.foxai.com.vn
PUBLIC_URL=https://uatnative.foxai.com.vn
CORS_ORIGIN=https://uatnative.foxai.com.vn

# ─── Misc ────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
