# ============================================================
# FOXAI NATIVE – Environment Variables Template
# Sao chép file này thành .env và điền giá trị thực tế
# ============================================================

# ─── System DB (apps/system-service) ────────────────────────
SYSTEM_DATABASE_URL="postgresql://system_user:system_pass@localhost:5432/system_db"

# ─── OCR DB (apps/ocr-service) ──────────────────────────────
OCR_DATABASE_URL="postgresql://ocr_user:ocr_pass@localhost:5433/ocr_db"

# ─── Chatbot DB (apps/chatbot-service) ──────────────────────
CHATBOT_DATABASE_URL="postgresql://chatbot_user:chatbot_pass@localhost:5434/chatbot_db"

# ─── Redis / BullMQ ─────────────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
BULLMQ_PREFIX="foxai"

# ─── Auth / JWT (API Gateway) ───────────────────────────────
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ─── gRPC endpoints (API Gateway → Services) ────────────────
SYSTEM_SERVICE_GRPC_URL="localhost:50051"
OCR_SERVICE_GRPC_URL="localhost:50052"
CHATBOT_SERVICE_GRPC_URL="localhost:50053"

# ─── App ports ──────────────────────────────────────────────
WEB_PORTAL_PORT=3000
API_GATEWAY_PORT=3001
SYSTEM_SERVICE_PORT=3002
OCR_SERVICE_PORT=3003
CHATBOT_SERVICE_PORT=3004

# ─── OCR Provider (apps/ocr-service) ────────────────────────
# Giá trị: mock | local-pdf | google-document-ai | aws-textract | fpt-ai
OCR_PROVIDER="mock"
OCR_API_KEY=""
OCR_PROJECT_ID=""
OCR_PROCESSOR_ID=""

# ─── Embedding / LLM (apps/chatbot-service) ─────────────────
OPENAI_API_KEY="sk-xxxxxxxxxxxx"
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_DIMENSIONS=1536

# ─── Frontend ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ─── Worker ─────────────────────────────────────────────────
WORKER_CONCURRENCY=30

# ─── Misc ───────────────────────────────────────────────────
NODE_ENV="development"
LOG_LEVEL="debug"
