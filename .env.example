# ============================================================
# FOXAI NATIVE – Environment Variables Template
# Sao chép file này thành .env và điền giá trị thực tế
# ============================================================

# ─── System DB (apps/system-service) ────────────────────────
# Raw credentials cho Postgres container init (KHÔNG URL-encode)
SYSTEM_DB_USER=postgres
SYSTEM_DB_PASSWORD=postgres
SYSTEM_DB_NAME=system_db

# Native dev (.NET chạy trên host) - kết nối localhost
# Nếu password có ký tự đặc biệt (@ % # ?) thì PHẢI URL-encode (@→%40, %→%25, #→%23, ?→%3F)
SYSTEM_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/system_db"

# Docker compose (.NET chạy trong container) - kết nối service DNS
SYSTEM_DATABASE_URL_DOCKER="postgresql://postgres:postgres@system-db:5432/system_db"

# ─── OCR DB (apps/ocr-service) ──────────────────────────────
OCR_DATABASE_URL="postgresql://ocr_user:ocr_pass@localhost:5433/ocr_db"

# ─── Chatbot DB (apps/chatbot-service) ──────────────────────
CHATBOT_DATABASE_URL="postgresql://chatbot_user:chatbot_pass@localhost:5434/chatbot_db"

# ─── Knowledge DB (apps/knowledge-service) ──────────────────
KNOWLEDGE_DB_USER=kb_user
KNOWLEDGE_DB_PASSWORD=kb_pass
KNOWLEDGE_DB_NAME=knowledge_db

# Native dev (.NET chạy trên host) - port 5435
KNOWLEDGE_DATABASE_URL="postgresql://kb_user:kb_pass@localhost:5435/knowledge_db"

# Docker compose - kết nối service DNS
KNOWLEDGE_DATABASE_URL_DOCKER="postgresql://kb_user:kb_pass@knowledge-db:5432/knowledge_db"

KNOWLEDGE_SERVICE_PORT=3005
KNOWLEDGE_SERVICE_GRPC_URL="localhost:52052"

# ─── Redis / BullMQ ─────────────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
BULLMQ_PREFIX="foxai"

# ─── Auth / JWT (API Gateway) ───────────────────────────────
JWT_SECRET="ac535ceae103326863b70bee405473059f2cbf1aa1905c9ee6f6ba9aa1ebeb35"
JWT_EXPIRES_IN="7d"

# ─── gRPC endpoints (API Gateway → Services) ────────────────
# Lưu ý port: trên Windows, dải 49960-50059 thường bị HyperV/WSL2 reserve.
# Các service đã đẩy port ra ngoài dải này (51051+).
# - Cùng docker-compose network: dùng tên container + internal port (vd. system-service:50051)
# - Host gọi vào (native dev hoặc Docker host mapping): dùng URL bên dưới
SYSTEM_SERVICE_GRPC_URL="localhost:51051"
OCR_SERVICE_GRPC_URL="localhost:51052"
CHATBOT_SERVICE_GRPC_URL="localhost:51053"

# ─── App ports ──────────────────────────────────────────────
WEB_PORTAL_PORT=3000
API_GATEWAY_PORT=3001

# System Service: gRPC + HTTP health.
# Host bind 51051 (Windows reserve 49960-50059 cho HyperV); container internal vẫn 50051.
SYSTEM_SERVICE_PORT=3002
GRPC_PORT=51051
HTTP_PORT=3002

OCR_SERVICE_PORT=3003
CHATBOT_SERVICE_PORT=3004

# ─── OCR Provider (apps/ocr-service) ────────────────────────
# Giá trị: mock | local-pdf | google-document-ai | aws-textract | fpt-ai
OCR_PROVIDER="mock"
OCR_API_KEY=""
OCR_PROJECT_ID=""
OCR_PROCESSOR_ID=""

# ─── Embedding / LLM (apps/chatbot-service) ─────────────────
OPENAI_API_KEY="sk-xxxxxxxxxxxx"
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_DIMENSIONS=1536

# ─── Frontend ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"

# ─── Worker ─────────────────────────────────────────────────
WORKER_CONCURRENCY=3

# ─── Misc ───────────────────────────────────────────────────
NODE_ENV="development"
LOG_LEVEL="debug"
