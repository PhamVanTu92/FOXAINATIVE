# ==========================================
# INDEX SERVICE (Python/FastAPI) ENV
# Copy to apps/index-service/.env and fill in secrets.
# ==========================================

# ─── JWT (shared with system-service .NET via HS256) ───────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string-32+
JWT_ISSUER=foxai-system-service
JWT_AUDIENCE=foxai-platform

# ─── PostgreSQL ─────────────────────────────────────────────────────
POSTGRES__HOST=index-py-postgres
POSTGRES__PORT=5432
POSTGRES__USERNAME=postgres
POSTGRES__PASSWORD=postgres
POSTGRES__DB=index_py_db
POSTGRES__POOL_SIZE=10
POSTGRES__MAX_OVERFLOW=20

# ─── Inter-service ──────────────────────────────────────────────────
AUTH_SERVICE_URL=http://api-gateway:3001
INDEX_SERVICE_URL=http://index-service:8000
QUERY_SERVICE_URL=http://chatbot-service:8000

# ─── Embedding providers (for document chunking) ───────────────────
OPENAI__API_KEY=
OPENAI__EMBEDDING_MODEL=text-embedding-3-large
OPENAI__EMBEDDING_SIZE=3072

GEMINI__API_KEY=
GEMINI__EMBEDDING_MODEL=models/gemini-embedding-001

# ─── Vector store / object store ────────────────────────────────────
QDRANT_URL=http://qdrant:6333
MINIO__USERNAME=minio
MINIO__PASSWORD=minio_password
MINIO__ENDPOINT=minio:9000

# ─── Redis (for BullMQ-style background jobs / ETL) ─────────────────
REDIS_HOST=redis
REDIS_PORT=6379

ROOT_PATH=/index
