{
  "name": "@foxai/widget-sdk",
  "version": "1.0.0",
  "description": "FoxAI Chat Widget SDK - Embeddable chatbot widget",
  "type": "module",
  "main": "dist/sdk.js",
  "module": "dist/sdk.esm.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "rollup -c -w",
    "build": "rollup -c",
    "build:dev": "NODE_ENV=development rollup -c",
    "build:prod": "NODE_ENV=production rollup -c",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "chatbot",
    "widget",
    "foxai",
    "sdk"
  ],
  "author": "FoxAI",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-replace": "^5.0.5",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^20.11.17",
    "dotenv": "^16.4.5",
    "postcss": "^8.4.35",
    "rollup": "^4.12.0",
    "rollup-plugin-postcss": "^4.0.2",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3"
  }
}
