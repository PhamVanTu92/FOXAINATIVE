# Development Environment Configuration
# Override .env for local development

# API Configuration
VITE_API_BASE_URL=https://chatbotnative.foxai.com.vn
VITE_API_VERSION=v1

# Provider Configuration
VITE_DEFAULT_PROVIDER_LLM=openai
VITE_DEFAULT_PROVIDER_STORAGE=qdrant
VITE_DEFAULT_PROVIDER_EMBEDDING=foxaillm
VITE_DEFAULT_COLLECTION_NAME=foxai_native_default

# UI Configuration — fallback only; the operator's chatbot config wins.
VITE_DEFAULT_BOT_NAME=Trợ lý FoxAI Native
VITE_DEFAULT_BOT_AVATAR=
VITE_DEFAULT_GREETING=Xin chào! Tôi có thể giúp gì cho bạn?
VITE_DEFAULT_PRIMARY_COLOR=#0066cc

# Development Configuration
VITE_DEBUG_MODE=true
VITE_LOG_LEVEL=debug