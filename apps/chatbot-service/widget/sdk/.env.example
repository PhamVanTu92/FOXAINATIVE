# FoxAI Widget SDK Environment Configuration Template
# Copy this file to .env and customize for your environment

# API Configuration
VITE_API_BASE_URL=https://your-api-domain.com/query
VITE_API_VERSION=v1

# Provider Configuration  
VITE_DEFAULT_PROVIDER_LLM=openai
VITE_DEFAULT_PROVIDER_STORAGE=qdrant
VITE_DEFAULT_PROVIDER_EMBEDDING=foxaillm
VITE_DEFAULT_COLLECTION_NAME=YOUR_COLLECTION

# UI Configuration
VITE_DEFAULT_BOT_NAME=Your Bot Name
VITE_DEFAULT_BOT_AVATAR=https://your-domain.com/bot-avatar.png
VITE_DEFAULT_GREETING=Hello! How can I help you today?
VITE_DEFAULT_PRIMARY_COLOR=#0066cc

# Development Configuration
VITE_DEBUG_MODE=false
VITE_LOG_LEVEL=info