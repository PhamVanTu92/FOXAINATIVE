# ==========================================
# CHATBOT SERVICE (Python/FastAPI) ENV
# Copy to apps/chatbot-service/.env and fill in secrets.
# ==========================================

# ─── JWT (shared with system-service .NET via HS256) ───────────────
# MUST match Jwt:Secret in apps/system-service/src/SystemService.Api/appsettings.json
JWT_SECRET=change-me-in-production-use-a-long-random-string-32+
JWT_ISSUER=foxai-system-service
JWT_AUDIENCE=foxai-platform

# ─── PostgreSQL (foxai-chatbot-py-postgres in docker-compose) ──────
POSTGRES__HOST=chatbot-py-postgres
POSTGRES__PORT=5432
POSTGRES__USERNAME=postgres
POSTGRES__PASSWORD=postgres
POSTGRES__DB=chatbot_py_db
POSTGRES__POOL_SIZE=15
POSTGRES__MAX_OVERFLOW=20
POSTGRES__POOL_TIMEOUT=30
POSTGRES__POOL_RECYCLE=1800

# ─── Inter-service URLs (used by chatbot-service to call index-service) ──
AUTH_SERVICE_URL=http://api-gateway:3001
INDEX_SERVICE_URL=http://index-service:8000
QUERY_SERVICE_URL=http://chatbot-service:8000

# ─── LLM providers ──────────────────────────────────────────────────
OPENAI__API_KEY=
OPENAI__MODEL_NAME=gpt-4.1-2025-04-14
OPENAI__EMBEDDING_MODEL=text-embedding-3-large
OPENAI__STREAMING=True
OPENAI__MAX_OUTPUT_TOKENS=8092
OPENAI__EMBEDDING_SIZE=3072

GEMINI__API_KEY=
GEMINI__MODEL_NAME=gemini-2.5-flash
GEMINI__EMBEDDING_MODEL=models/gemini-embedding-001
GEMINI__VOICE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
GEMINI__TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI__TTS_VOICE_NAME=Kore

CLAUDE__API_KEY=
CLAUDE__MODEL_NAME=claude-3-7-sonnet-20250219
CLAUDE__EMBEDDING_MODEL=voyage-3-large

FOXAILLM__API_KEY=
FOXAILLM__BASE_URL=
FOXAILLM__MODEL_NAME=foxai-gpt-core

# ─── Storage / vector DB ────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
MINIO__USERNAME=minio
MINIO__PASSWORD=minio_password
MINIO__ENDPOINT=minio:9000

# ─── Redis (for langgraph checkpointer + Mem0) ──────────────────────
REDIS__CHECKPOINTER_BACKEND=redis
REDIS__CHECKPOINTER_TTL_MINUTES=1440
REDIS__CHECKPOINTER_REFRESH_ON_READ=true
REDIS_HOST=redis
REDIS_PORT=6379

# ─── Mem0 personalization (scoped by user_id::bot::<chatbot_id>) ────
MEM0__ENABLED=true
MEM0__COLLECTION_NAME=user_memory
MEM0__MAX_MEMORIES=5
MEM0__RELEVANCE_THRESHOLD=0.3
MEM0__STORE_TIMEOUT=30.0
MEM0__RETRIEVE_TIMEOUT=10.0

# ─── Voice + Embed snippet ──────────────────────────────────────────
# Public origin where the SDK is served — embedded into generated snippets.
EMBED_BASE_URL=

# ─── Monitoring ────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=foxainative

# Single worker — cpu_count fork-mode crashes on big hosts due to DB/Redis/Qdrant
# connection pool exhaustion. Raise pool sizes before raising this.
UVICORN_WORKERS=1
ROOT_PATH=/chatbot
