              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "grpc://{{grpcUrl}}/foxai.system.OrganizationsService/GetNode",
              "protocol": "grpc",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["foxai.system.OrganizationsService", "GetNode"]
            },
            "description": "**gRPC:** `foxai.system.OrganizationsService/GetNode`\n\nTrả 1 node (không kèm children — dùng `GetTree` nếu muốn cây)."
